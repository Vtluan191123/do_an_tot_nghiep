# Environment Variables Template
# Copy this file and rename to .env.dev or .env.prod
# ==================================================

# Application
APP_ENV=dev
APP_NAME=Web Integration AI

# Backend - Database SQL Server
DB_HOST=159.223.56.71
DB_PORT=1433
DB_NAME=do_an_tot_nghiep
DB_USER=sa
DB_PASSWORD=your_password_here
DB_ENCRYPT=true

# Backend - MongoDB
MONGODB_HOST=159.223.56.71
MONGODB_PORT=27017
MONGODB_NAME=do_an_tot_nghiep

# Backend - Spring Boot
SPRING_PROFILES_ACTIVE=dev
JAVA_OPTS=-Xmx512m -Xms256m
SERVER_PORT=8080

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRATION_ACCESS=99999999
JWT_EXPIRATION_REFRESH=3600000

# File Upload
FILE_UPLOAD_DIR=./uploads

# Gemini API
GEMINI_API_KEY=your_api_key_here
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_PRIMARY_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODEL=gemini-2.5-pro

# WebSocket Integration
WEBSOCKET_DOMAIN=https://socket.easypos.vn
WEBSOCKET_PREFIX_FANOUT=/topics/
WEBSOCKET_PREFIX_DIRECT=/user/topics/

# Frontend
FRONTEND_PORT=4200
API_BASE_URL=http://localhost:8080

# Docker
BACKEND_CONTAINER_NAME=datn_be_dev
FRONTEND_CONTAINER_NAME=datn_fe_dev

# SSL Certificates (for production only)
SSL_CERT_PATH=/root/ssl

